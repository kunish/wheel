# Wheel - Docker Compose Environment Variables
# Copy this file to .env and fill in the values

# ── Authentication ──────────────────────────────────────

# Required: JWT secret for admin authentication (change in production!)
JWT_SECRET=your-secret-key-here

# Optional: Admin credentials (defaults shown)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# ── Database ────────────────────────────────────────────

# TiDB/MySQL connection string
# DB_DSN=root:@tcp(127.0.0.1:4000)/wheel?parseTime=true&charset=utf8mb4

# ── Server ──────────────────────────────────────────────

# Worker listen port
# PORT=8787

# Embedded Codex runtime starts automatically and always runs in fail-fast mode

# ── Observability ───────────────────────────────────────

# Enable Prometheus metrics endpoint
# METRICS_ENABLED=true

# Enable OpenTelemetry tracing
# OTEL_ENABLED=true

# OpenTelemetry collector endpoint
# OTEL_EXPORTER_ENDPOINT=localhost:4317

# Service name reported to OpenTelemetry
# OTEL_SERVICE_NAME=wheel-gateway

# ── Monitoring (Docker Compose) ─────────────────────────

# Grafana admin credentials
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
