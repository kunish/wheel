# Wheel - Docker Compose Environment Variables
# Copy this file to .env and fill in the values

# Required: JWT secret for admin authentication
JWT_SECRET=your-secret-key-here

# Optional: TiDB/MySQL connection string
# DB_DSN=root:@tcp(127.0.0.1:4000)/wheel?parseTime=true&charset=utf8mb4

# Optional: Admin credentials (defaults shown)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# Optional: Override default ports
# WEB_PORT=3000
# WORKER_PORT=8787
