{
  "name": "wheel",
  "version": "1.1.0",
  "private": true,
  "packageManager": "pnpm@10.29.2",
  "scripts": {
    "dev": "npx concurrently \"pnpm --filter @wheel/web run dev\" \"cd apps/worker && make dev\"",
    "dev:web": "pnpm --filter @wheel/web run dev",
    "dev:worker": "cd apps/worker && make dev",
    "build": "pnpm --filter @wheel/web run build",
    "build:web": "pnpm --filter @wheel/web run build",
    "build:worker": "cd apps/worker && make build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "deploy:web": "vercel deploy --prod",
    "docker:push": "docker buildx bake --push",
    "prepare": "husky"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.4.2",
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@eslint-react/eslint-plugin": "^2.12.4",
    "eslint": "^10.0.0",
    "eslint-plugin-react-refresh": "^0.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2"
  },
  "lint-staged": {
    "*.{ts,tsx,mjs,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,yaml,yml}": [
      "prettier --write"
    ]
  }
}
