{
  "name": "wheel",
  "version": "1.35.0",
  "private": true,
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "dev": "npx concurrently \"pnpm --filter @wheel/web run dev\" \"cd apps/worker && make dev\"",
    "dev:web": "pnpm --filter @wheel/web run dev",
    "dev:worker": "cd apps/worker && make dev",
    "build": "pnpm --filter @wheel/web run build",
    "build:web": "pnpm --filter @wheel/web run build",
    "build:worker": "cd apps/worker && make build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "docker:push": "docker buildx bake --push",
    "prepare": "husky"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:",
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@eslint-react/eslint-plugin": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-react-refresh": "catalog:",
    "husky": "catalog:",
    "lint-staged": "catalog:",
    "prettier": "catalog:",
    "prettier-plugin-tailwindcss": "catalog:"
  },
  "lint-staged": {
    "*.{ts,tsx,mjs,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,yaml,yml}": [
      "prettier --write"
    ]
  }
}
